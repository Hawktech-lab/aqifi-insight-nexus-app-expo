                    <View style={styles.collectionControlInfo}>
                      <Icon name="flash" size={20} color="#007AFF" />
                      <View style={styles.collectionControlText}>
                        <Text style={styles.collectionControlTitle}>Analyze Behavioral Data</Text>
                        <Text style={styles.collectionControlDescription}>Generate insights from your activity patterns</Text>
                      </View>
                    </View>
                    <TouchableOpacity 
                      style={styles.collectButton}
                      onPress={async () => {
                        setCollectingData(true);
                        try {
                          if (!behavioralInitialized) {
                            const granted = await requestBehavioralPermission();
                            if (!granted) {
                               Alert.alert('Permission Required', 'Behavioral analytics requires initialization.');
                              return;
                            }
                          }
                          
                          if (!behavioralEnabled) {
                            await enableBehavioralStream();
                          }
                          
                          // Run behavioral analysis
                          const insights = await analyzeBehavior();
                          
                           Alert.alert(
                             "Behavioral Analysis Complete",
                             `Successfully generated ${insights.length} behavioral insights from your data patterns.`
                           );
                        } catch (error: any) {
                          console.error('Behavioral analysis error:', error);
                           Alert.alert(
                             "Error",
                             `Failed to analyze behavioral data: ${error?.message || 'Unknown error'}`
                           );
                        } finally {
                          setCollectingData(false);
                        }
                      }}
                      disabled={collectingData || isAnalyzing}
                    >
                      <Icon name={collectingData || isAnalyzing ? "refresh" : "play"} size={16} color="#fff" />
                      <Text style={styles.collectButtonText}>
                        {collectingData || isAnalyzing ? 'Analyzing...' : 'Analyze Now'}
                      </Text>
                    </TouchableOpacity>
                  </View>

                  <View style={styles.collectionControl}>
                    <View style={styles.collectionControlInfo}>
                      <Icon name="refresh" size={20} color="#007AFF" />
                      <View style={styles.collectionControlText}>
                        <Text style={styles.collectionControlTitle}>Collect All Data</Text>
                        <Text style={styles.collectionControlDescription}>Run full data collection for all enabled streams</Text>
                      </View>
                    </View>
                    <TouchableOpacity 
                      style={[styles.collectButton, styles.collectAllButton]}
                      onPress={() => triggerDataCollection('all')}
                      disabled={collectingData}
                    >
                      <Icon name={collectingData ? "refresh" : "play"} size={16} color="#fff" />
                      <Text style={styles.collectButtonText}>
                        {collectingData ? 'Collecting...' : 'Collect All'}
                      </Text>
                    </TouchableOpacity>
                  </View>
                </View>

                <View style={styles.automatedCollectionInfo}>
                  <Icon name="checkmark-circle" size={16} color="#007AFF" />
                  <View style={styles.automatedCollectionText}>
                    <Text style={styles.automatedCollectionTitle}>Automated Collection Active</Text>
                    <Text style={styles.automatedCollectionDescription}>
                      Data is automatically collected every 5-30 minutes when streams are enabled. 
                      Manual collection is for testing and immediate updates.
                    </Text>
                  </View>
                </View>
              </View>
            </View>

            {/* Notifications */}
            <View style={styles.card}>
              <View style={styles.cardHeader}>
                <Icon name="notifications" size={20} color="#007AFF" />
                <Text style={styles.cardTitle}>Notifications</Text>
              </View>
              <View style={styles.cardContent}>
                <View style={styles.notificationSetting}>
                  <View style={styles.notificationInfo}>
                    <Text style={styles.notificationTitle}>New Survey Alerts</Text>
                    <Text style={styles.notificationDescription}>Get notified about new earning opportunities</Text>
                  </View>
                  <View style={styles.notificationToggle}>
                    <Text style={styles.notificationToggleText}>Enabled</Text>
                  </View>
                </View>
                
                <View style={styles.notificationSetting}>
                  <View style={styles.notificationInfo}>
                    <Text style={styles.notificationTitle}>Earnings Updates</Text>
                    <Text style={styles.notificationDescription}>Weekly summary of your earnings</Text>
                  </View>
                  <View style={styles.notificationToggle}>
                    <Text style={styles.notificationToggleText}>Enabled</Text>
                  </View>
                </View>
              </View>
            </View>
          </View>
        )}

        {/* Debug & Support Section */}
        {/*<View style={styles.card}>
          <View style={styles.cardHeader}>
            <Icon name="bug" size={20} color="#007AFF" />
            <Text style={styles.cardTitle}>Debug & Support</Text>
          </View>
          <View style={styles.cardContent}>
            <TouchableOpacity 
              style={styles.debugButton}
              onPress={() => {
                const logs = errorLogger?.getLogs?.() || [];
                if (logs.length === 0) {
                  // Alert.alert('No Errors', 'No error logs found. The app is running smoothly!');
                } else {
                  setShowErrorLogs(true);
                }
              }}
            >
              <View style={styles.debugButtonContent}>
                <Icon name="document-text" size={20} color="#007AFF" />
                <View style={styles.debugButtonText}>
                  <Text style={styles.debugButtonTitle}>View Error Logs</Text>
                  <Text style={styles.debugButtonSubtitle}>
                    {errorLogCount} error(s) logged
                  </Text>
                </View>
              </View>
              <Icon name="chevron-forward" size={20} color="#8E8E93" />
            </TouchableOpacity>
          </View>
        </View> */}

        {/* Sign Out */}
        <TouchableOpacity style={[styles.card, styles.signOutCard]} onPress={handleSignOut}>
          <Icon name="log-out" size={20} color="#FF3B30" />
          <Text style={styles.signOutText}>Sign Out</Text>
        </TouchableOpacity>
      </View>
    </ScrollView>

    {/* Third-Party Confirmation Modal */}
    <ThirdPartyConfirmationModal
      visible={showThirdPartyConfirmation}
      onConfirm={() => {
        setShowThirdPartyConfirmation(false);
        setShowKyc(true);
      }}
      onDecline={() => {
        setShowThirdPartyConfirmation(false);
      }}
      thirdPartyName="zkMe"
    />

    {/* Error Log Viewer Modal */}
    <ErrorLogViewer 
      visible={showErrorLogs} 
      onClose={() => setShowErrorLogs(false)} 
    />

    {/* ZkMe KYC Verification Modal - Outside ScrollView */}
    {showKyc && (
      <ErrorBoundary 
        onError={(error) => {
          console.error('ZkMeWebView Error:', error);
          setShowKyc(false);
          setZkMeComponent(null);
          setZkMeError(null);
          setZkMeLoading(false);
           Alert.alert('Error', 'Failed to load KYC verification. Please try again later.');
        }}
        fallback={
          <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', padding: 20, backgroundColor: '#fff' }}>
            <Text style={{ fontSize: 16, color: '#666', textAlign: 'center', marginBottom: 20 }}>
              Something went wrong loading KYC verification.
            </Text>
            <TouchableOpacity 
              onPress={() => {
                setShowKyc(false);
                setZkMeComponent(null);
                setZkMeError(null);
                setZkMeLoading(false);
              }}
              style={{ padding: 12, backgroundColor: '#007AFF', borderRadius: 8 }}
            >
              <Text style={{ color: '#fff', fontWeight: '600' }}>Close</Text>
            </TouchableOpacity>
          </View>
        }
      >
        {zkMeLoading && (
          <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#fff' }}>
            <ActivityIndicator size="large" color="#007AFF" />
            <Text style={{ marginTop: 16, fontSize: 16, color: '#666' }}>Loading KYC verification...</Text>
          </View>
        )}
        {zkMeError && (
          <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', padding: 20, backgroundColor: '#fff' }}>
            <Text style={{ fontSize: 16, color: '#FF3B30', textAlign: 'center', marginBottom: 20 }}>
              {zkMeError}
            </Text>
            <TouchableOpacity 
              onPress={() => {
                setShowKyc(false);
                setZkMeComponent(null);
                setZkMeError(null);
                setZkMeLoading(false);
              }}
              style={{ padding: 12, backgroundColor: '#007AFF', borderRadius: 8 }}
            >
              <Text style={{ color: '#fff', fontWeight: '600' }}>Close</Text>
            </TouchableOpacity>
          </View>
        )}
        {!zkMeLoading && !zkMeError && ZkMeComponent && (() => {
          try {
            // Alert.alert('DEBUG', 'Step 7: Rendering ZkMeComponent - validating component');
            console.log('DEBUG: Step 7 - Rendering ZkMeComponent', { 
              zkMeLoading, 
              zkMeError, 
              hasZkMeComponent: !!ZkMeComponent,
              componentType: typeof ZkMeComponent 
            });
            // Ensure ZkMeComponent is a valid React component
            if (typeof ZkMeComponent !== 'function' && typeof ZkMeComponent !== 'object') {
              throw new Error('Invalid ZkMe component');
            }
            
            // Alert.alert('DEBUG', 'Step 8: Component validated, creating Component instance');
            console.log('DEBUG: Step 8 - Component validated, creating Component instance');
            const Component = ZkMeComponent as React.ComponentType<any>;
            // Alert.alert('DEBUG', 'Step 9: About to render Component with props');
            console.log('DEBUG: Step 9 - About to render Component', {
              visible: showKyc,
              walletAddress: walletAddress || 'no-wallet'
            });
            return (
              <Component
                key={`zkme-kyc-${showKyc ? 'open' : 'closed'}-${walletAddress || 'no-wallet'}`}
                visible={showKyc}
                onClose={() => {
                  // Use setTimeout to make close non-blocking and prevent UI hang
                  setTimeout(() => {
                    try {
                      console.log('KYC modal closed by user');
                      setShowKyc(false);
                      // State will be reset by the cleanup useEffect
                    } catch (error) {
                      console.error('Error closing KYC modal:', error);
                    }
                  }, 0);
                }}
                onComplete={(result: any) => {
                  try {
                    console.log('KYC verification completed successfully');
                    handleKycComplete(result);
                  } catch (error) {
                    console.error('Error in KYC completion handler:', error);
                    Alert.alert('Error', 'Failed to process KYC completion. Please try again.');
                    setShowKyc(false);
                  }
                }}
                onError={(error: Error | string) => {
                  try {
                    handleKycError(error);
                  } catch (handlerError) {
                    console.error('Error in KYC error handler:', handlerError);
                    // Fallback: just close the modal
                    setShowKyc(false);
                    setZkMeComponent(null);
                    setZkMeError(null);
                    setZkMeLoading(false);
                  }
                }}
                userId={user?.id}
                dappName="Aqifi Insight Nexus"
                chainId="1"
              />
            );
          } catch (error: any) {
            console.error('Error rendering ZkMeComponent:', error);
            const errorMessage = error?.message || 'Failed to render KYC verification component';
            setZkMeError(errorMessage);
            setZkMeLoading(false);
            setShowKyc(false);
            return null;
          }
        })()}
      </ErrorBoundary>
    )}
  </View>
  );
};



// Admin Screen - Using the comprehensive Admin component
const AdminScreen = () => {
  return (
    <ErrorBoundary onError={(error) => console.error('Admin Error:', error)}>
      <Admin />
    </ErrorBoundary>
  );
};

// Simple Error Boundary Component
interface ErrorBoundaryProps {
  children: React.ReactNode;
  onError?: (error: Error) => void;
  fallback?: React.ReactNode;
}

interface ErrorBoundaryState {
  hasError: boolean;
}

class ErrorBoundary extends React.Component<ErrorBoundaryProps, ErrorBoundaryState> {
  constructor(props: ErrorBoundaryProps) {
    super(props);
    this.state = { hasError: false };
  }

  static getDerivedStateFromError(error: Error): ErrorBoundaryState {
    return { hasError: true };
  }

  componentDidCatch(error: Error, errorInfo: React.ErrorInfo) {
    console.error('Error Boundary caught an error:', error, errorInfo);
    if (this.props.onError) {
      this.props.onError(error);
    }
  }

  render() {
    if (this.state.hasError) {
      // Return a fallback UI instead of null to prevent blank screen
      return this.props.fallback || (
        <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', padding: 20 }}>
          <Text style={{ fontSize: 16, color: '#666', textAlign: 'center' }}>
            Something went wrong. Please try again.
          </Text>
        </View>
      );
    }

    return this.props.children;
  }
}

// Helper function to check if KYC is completed - shared utility
const isKycCompleted = (status: string | null | undefined): boolean => {
  return status === 'verified' || status === 'rejected' || status === 'error';
};

// KYC Screen Component - Now uses zk KYC widget
const KYCScreen = ({ navigation }: any) => {
  const { user } = useAuth();
  const { profile, loading: profileLoading } = useProfile();
  // Make waitlist check non-blocking - don't wait for loading state
  // Default to enabled, Waitlist screen will handle errors internally
  let waitlistEnabled = true;
  let waitlistLoading = false;
  let waitlistError: any = null;
  try {
    const waitlistHook = useWaitlistEnabled();
    waitlistEnabled = waitlistHook?.enabled ?? true;
    waitlistLoading = waitlistHook?.loading ?? false;
    waitlistError = waitlistHook?.error ?? null;
  } catch (e) {
    // If waitlist hook fails, default to enabled (non-blocking)
    console.warn('Waitlist hook error, defaulting to enabled:', e);
  }
  const queryClient = useQueryClient();
  const kycStatus = profile?.kyc_status;
  const [showZkKycWidget, setShowZkKycWidget] = useState(false);
  const [ZkMeComponent, setZkMeComponent] = useState<React.ComponentType<any> | null>(null);
  const [zkMeLoading, setZkMeLoading] = useState(false);
  const [checkingKycStatus, setCheckingKycStatus] = useState(false);
  const [zkMeError, setZkMeError] = useState<string | null>(null);
  const loadTimeoutRef = useRef<NodeJS.Timeout | null>(null);
  const statusCheckTimeoutRef = useRef<NodeJS.Timeout | null>(null);
  const isMountedRef = useRef(true);
  const hasNavigatedRef = useRef(false);

  // Set mounted flag on mount and cleanup on unmount
  useEffect(() => {
    isMountedRef.current = true;
    return () => {
      isMountedRef.current = false;
      // Cleanup timeouts on unmount
      if (loadTimeoutRef.current) {
        clearTimeout(loadTimeoutRef.current);
        loadTimeoutRef.current = null;
      }
      if (statusCheckTimeoutRef.current) {
        clearTimeout(statusCheckTimeoutRef.current);
        statusCheckTimeoutRef.current = null;
      }
    };
  }, []);

  // Lazy load ZkMe component
  useEffect(() => {
    if (showZkKycWidget && !ZkMeComponent && !zkMeLoading && !zkMeError) {
      setZkMeLoading(true);
      setZkMeError(null);
      
      // Clear any existing timeout
      if (loadTimeoutRef.current) {
        clearTimeout(loadTimeoutRef.current);
        loadTimeoutRef.current = null;
      }
      
      // Set a timeout to prevent infinite hanging (15 seconds)
      const timeout = setTimeout(() => {
        console.error('ZkMe component loading timeout');
        setZkMeLoading(false);
        setZkMeError('Failed to load KYC verification component. Please try again.');
        setShowZkKycWidget(false);
        loadTimeoutRef.current = null;
        // Navigate to Dashboard on timeout error
        Alert.alert(
          'KYC Verification Error',
          'KYC verification component is taking too long to load. Please check your connection and try again.',
          [
            {
              text: 'OK',
              onPress: () => {
                navigation.replace('MainTabs', { screen: 'Dashboard' });
              }
            }
          ]
        );
      }, 15000);
      loadTimeoutRef.current = timeout;
      
      import('./components/ZkMeWebView')
        .then((module) => {
          // Clear timeout on success
          if (loadTimeoutRef.current) {
            clearTimeout(loadTimeoutRef.current);
            loadTimeoutRef.current = null;
          }
          
          if (!showZkKycWidget) {
            setZkMeLoading(false);
            return;
          }
          try {
            const ZkMeWebView = module.default || module.ZkMeWebView;
            if (!ZkMeWebView) {
              throw new Error('ZkMe component export is undefined or invalid');
            }
            setZkMeComponent(() => ZkMeWebView);
            setZkMeLoading(false);
            setZkMeError(null);
          } catch (error: any) {
            console.error('Failed to initialize ZkMe component:', error);
            setZkMeLoading(false);
            setZkMeError(error?.message || 'Failed to initialize KYC verification');
            setShowZkKycWidget(false);
            // Navigate to Dashboard on initialization error
            Alert.alert(
              'KYC Verification Error',
              'Failed to initialize KYC verification. Please check your configuration and try again later.',
              [
                {
                  text: 'OK',
                  onPress: () => {
                    navigation.replace('MainTabs', { screen: 'Dashboard' });
                  }
                }
              ]
            );
          }
        })
        .catch((error: any) => {
          // Clear timeout on error
          if (loadTimeoutRef.current) {
            clearTimeout(loadTimeoutRef.current);
            loadTimeoutRef.current = null;
          }
          console.error('Failed to load ZkMe component module:', error);
          setZkMeLoading(false);
          setZkMeError(error?.message || 'Failed to load KYC verification component');
          setShowZkKycWidget(false);
          // Navigate to Dashboard on module load error
          Alert.alert(
            'KYC Verification Error',
            'Failed to load KYC verification component. Please try again later.',
            [
              {
                text: 'OK',
                onPress: () => {
                  navigation.replace('MainTabs', { screen: 'Dashboard' });
                }
              }
            ]
          );
        });
    }
    
    // Cleanup timeout on unmount or when dependencies change
    return () => {
      if (loadTimeoutRef.current) {
        clearTimeout(loadTimeoutRef.current);
        loadTimeoutRef.current = null;
      }
    };
  }, [showZkKycWidget, ZkMeComponent, zkMeLoading, zkMeError]);

  // Helper function to add timeout to promises
  const withTimeout = <T,>(promise: Promise<T>, timeoutMs: number, errorMessage: string): Promise<T> => {
    return Promise.race([
      promise,
      new Promise<T>((_, reject) => 
        setTimeout(() => reject(new Error(errorMessage)), timeoutMs)
      )
    ]);
  };

  // Check zk KYC status function
  const checkZkMeVerificationStatus = async (): Promise<'verified' | 'pending' | 'error'> => {
    try {
      if (!user || !user.email) {
        return 'error';
      }

      let appId = '';
      try {
        const configService = AppConfigurationService.getInstance();
        const zkmeConfig = await configService.getZkMeConfig();
        appId = zkmeConfig.mchNo;
      } catch (error) {
        console.error('Error fetching ZkMe configuration:', error);
        return 'error';
      }

      if (!appId) {
        return 'error';
      }

      let programNo: string | undefined;
      try {
        const configService = AppConfigurationService.getInstance();
        const programNoValue = await configService.getConfigValue('zkme_program_no');
        programNo = programNoValue || undefined;
      } catch (error) {
        console.warn('Error fetching zkme_program_no:', error);
      }

      // Wrap the API call with a timeout (10 seconds) to prevent hanging
      const { isGrant } = await withTimeout(
        verifyKycWithZkMeServices(
          appId,
          user.id,
          programNo ? { programNo } : undefined
        ),
        10000,
        'KYC verification check timed out'
      );

      if (isGrant) {
        // Update profile if needed
        const currentAppStatus = profile?.kyc_status || 'pending';
        if (currentAppStatus === 'pending') {
          await supabase
            .from('profiles')
            .update({ kyc_status: 'verified' })
            .eq('user_id', user.id);
          queryClient.invalidateQueries(['profile', user.id]);
          await queryClient.refetchQueries(['profile', user.id]);
        }
        return 'verified';
      }

      // Check database as fallback
      const { data: submission } = await supabase
        .from('kyc_submissions')
        .select('verified_attributes')
        .eq('user_id', user.id)
        .eq('verification_method', 'zkme')
        .order('created_at', { ascending: false })
        .limit(1)
        .maybeSingle();

      const credentials = submission?.verified_attributes;
      if (Array.isArray(credentials) && credentials.length > 0) {
        const hasVerifiedCredential = credentials.some((cred: any) => cred?.status === 'verified');
        if (hasVerifiedCredential) {
          return 'verified';
        }
      }

      return 'pending';
    } catch (error) {
      console.error('Error checking ZkMe verification status:', error);
      // If it's a timeout error, log it specifically and return pending to allow widget to open
      if (error instanceof Error && error.message.includes('timed out')) {
        console.warn('KYC verification check timed out, proceeding with pending status');
        return 'pending'; // Return pending instead of error to allow widget to open
      }
      return 'error';
    }
  };

  // Check KYC status when component mounts - automatically open widget if not completed
  useEffect(() => {
    // If we have profile data (even if profileLoading is true), check KYC status
    // Only wait if profileLoading is true AND we don't have profile data yet
    if (profileLoading && profile === undefined) {
      return;
    }
    
    if (user && profile !== undefined) {
      // If KYC is verified, navigate based on waitlist status
      // If waitlist is loading, navigate to Waitlist (it will show loading)
      // If waitlist has errors, navigate to Dashboard (fallback)
      // If waitlist is disabled, navigate to Dashboard (fallback)
      if (kycStatus === 'verified') {
        if (!hasNavigatedRef.current) {
          hasNavigatedRef.current = true;
          // Check for waitlist errors first - if error, go to Dashboard
          if (waitlistError) {
            navigation.replace('MainTabs', { screen: 'Dashboard' });
          } else if (waitlistEnabled) {
            // Waitlist enabled and no errors - navigate to Waitlist (loading is fine)
            navigation.replace('MainTabs', { screen: 'Waitlist' });
          } else {
            // Waitlist disabled - go to Dashboard
            navigation.replace('MainTabs', { screen: 'Dashboard' });
          }
        }
        // Always return early for verified users
        return;
      }
      
      // If KYC is completed (rejected or error), navigate to dashboard
      if (isKycCompleted(kycStatus) && kycStatus !== 'verified') {
        navigation.replace('MainTabs', { screen: 'Dashboard' });
        return;
      }

      // Only call zk KYC API if database status is 'pending'
      if (kycStatus === 'pending') {
        setCheckingKycStatus(true);
        
        // Safety timeout to ensure checkingKycStatus is reset even if promise hangs
        const safetyTimeout = setTimeout(() => {
          if (isMountedRef.current) {
            console.warn('KYC status check taking too long, resetting state');
            setCheckingKycStatus(false);
            // Don't open widget on timeout - let user manually trigger it
          }
        }, 15000); // 15 seconds safety timeout
        
        checkZkMeVerificationStatus()
          .then((status) => {
            clearTimeout(safetyTimeout);
            if (!isMountedRef.current) return; // Don't update state if unmounted
            setCheckingKycStatus(false);
            if (status === 'verified') {
              // KYC verified - invalidate profile query to trigger useEffect hooks
              // The useEffect hooks will handle navigation once waitlist status is determined
              queryClient.invalidateQueries(['profile', user?.id]);
              queryClient.refetchQueries(['profile', user?.id]);
            } else if (status === 'pending') {
              // Only invoke widget if zk API returns 'pending' status
              setShowZkKycWidget(true);
            } else {
              // Status is 'error' - don't open widget automatically
              console.error('KYC status check returned error, user can manually retry');
            }
          })
          .catch((error) => {
            clearTimeout(safetyTimeout);
            if (!isMountedRef.current) return; // Don't update state if unmounted
            console.error('Error checking zk KYC status:', error);
            setCheckingKycStatus(false);
            // On error, navigate to Dashboard (dummy dashboard)
            navigation.replace('MainTabs', { screen: 'Dashboard' });
          });
      } else {
        // Database status is not 'pending' - don't call zk API or open widget
        // User can manually trigger KYC if needed
        console.log('KYC status is not pending, skipping automatic zk API call');
      }
    }
    
    // Cleanup function to clear safety timeout if effect re-runs or component unmounts
    return () => {
      // Note: safetyTimeout is scoped to the effect, so we can't clear it here directly
      // But the timeout will be cleared in the .then/.catch handlers above
    };
  }, [user, waitlistEnabled, waitlistError, navigation, kycStatus, profileLoading, profile]);
  // Note: isKycCompleted is a stable function defined outside component, no need in deps

  // Monitor KYC status changes - only navigate to waitlist if KYC is verified
  // This effect handles status changes AFTER initial mount check
  useEffect(() => {
    // Skip if we're still checking initial status to avoid race condition
    if (checkingKycStatus) return;
    
    // Navigate for verified users - check waitlist status
    // If waitlist has errors, go to Dashboard (fallback)
    // If waitlist is loading, that's fine - navigate to Waitlist (it will show loading)
    if (kycStatus === 'verified' && navigation && isMountedRef.current) {
      // Check for waitlist errors first - if error, go to Dashboard
      if (waitlistError) {
        navigation.replace('MainTabs', { screen: 'Dashboard' });
      } else if (waitlistEnabled) {
        // Waitlist enabled and no errors - navigate to Waitlist (loading is fine)
        navigation.replace('MainTabs', { screen: 'Waitlist' });
      } else {
        // Waitlist disabled - go to Dashboard
        navigation.replace('MainTabs', { screen: 'Dashboard' });
      }
    } else if (isKycCompleted(kycStatus) && kycStatus !== 'verified' && navigation && isMountedRef.current) {
      // KYC completed but not verified (rejected/error) - go to dashboard, not waitlist
      navigation.replace('MainTabs', { screen: 'Dashboard' });
    }
  }, [kycStatus, waitlistEnabled, waitlistError, navigation, checkingKycStatus]);
  // Note: isKycCompleted is a stable function defined outside component, no need in deps

  // Handle zk KYC completion
  const handleZkKycComplete = async (result: any) => {
    try {
      if (!user) return;

      let verificationPayload: ZkMeVerificationPayload | null = null;

      if (result?.verification_id && result?.credentials) {
        verificationPayload = {
          verification_id: result.verification_id,
          credentials: result.credentials
        };
      } else if (result?.verificationId && result?.credentials) {
        verificationPayload = {
          verification_id: result.verificationId,
          credentials: result.credentials
        };
      } else if (result?.type === 'zkme-verification-complete' && result?.result) {
        const nestedResult = result.result;
        if (nestedResult?.verification_id || nestedResult?.verificationId) {
          verificationPayload = {
            verification_id: nestedResult.verification_id || nestedResult.verificationId,
            credentials: nestedResult.credentials || []
          };
        }
      }

      if (verificationPayload) {
        await submitZkMeVerification(user.id, verificationPayload);
        
        if (!isMountedRef.current) return; // Check if still mounted after async operation
        
        await supabase
          .from('profiles')
          .update({ kyc_status: 'pending' })
          .eq('user_id', user.id);

        if (!isMountedRef.current) return; // Check again after async operation

        queryClient.invalidateQueries(['profile', user.id]);
        await queryClient.refetchQueries(['profile', user.id]);
      }

      if (!isMountedRef.current) return; // Check before updating state
      setShowZkKycWidget(false);

      // Clear any existing status check timeout
      if (statusCheckTimeoutRef.current) {
        clearTimeout(statusCheckTimeoutRef.current);
        statusCheckTimeoutRef.current = null;
      }

      // Check status again after a delay
      statusCheckTimeoutRef.current = setTimeout(async () => {
        // Check if component is still mounted before updating state/navigating
        if (!isMountedRef.current) return;
        
        const status = await checkZkMeVerificationStatus();
        if (!isMountedRef.current) return; // Check again after async operation
        
        if (status === 'verified') {
          // KYC verified - invalidate profile query to trigger useEffect hooks
          // The useEffect hooks will handle navigation once waitlist status is determined
          if (user) {
            queryClient.invalidateQueries(['profile', user.id]);
            queryClient.refetchQueries(['profile', user.id]);
          }
        } else {
          // KYC not verified yet - stay on KYC screen or go to dashboard
          // Don't navigate to waitlist until KYC is completed
          navigation.replace('MainTabs', { screen: 'Dashboard' });
        }
        statusCheckTimeoutRef.current = null;
      }, 1000);
    } catch (error: any) {
      console.error('Error handling zk KYC completion:', error);
      
      // Update profile status to 'error' to mark KYC as completed with error
      if (user) {
        try {
          await supabase
            .from('profiles')
            .update({ kyc_status: 'error' })
            .eq('user_id', user.id);
          
          queryClient.invalidateQueries(['profile', user.id]);
          await queryClient.refetchQueries(['profile', user.id]);
        } catch (updateError) {
          console.error('Error updating profile status to error:', updateError);
        }
      }
      
      Alert.alert(
        'KYC Verification Error',
        'Failed to process KYC verification. You can try again later.',
        [
          {
            text: 'OK',
            onPress: () => {
              setShowZkKycWidget(false);
              // Navigate to Dashboard - waitlist should only be shown after successful KYC
              navigation.replace('MainTabs', { screen: 'Dashboard' });
            }
          }
        ]
      );
    }
  };

  // Show loading while profile is loading or checking status or loading widget
  if (profileLoading) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
        <ActivityIndicator size="large" color="#007AFF" />
        <Text style={{ marginTop: 16, color: '#6b7280' }}>
          Loading...
        </Text>
      </View>
    );
  }
  
  // Safety check: If user is verified but we're still on this screen, navigate immediately
  // This handles edge cases where the useEffect might not have fired yet
  // Wait for waitlist status to be determined before navigating
  // Allow navigation even if profileLoading is true, as long as we have profile data
  useLayoutEffect(() => {
    // Only wait if profileLoading is true AND we don't have profile data yet
    if (profileLoading && profile === undefined) {
      return;
    }
    
    // Navigate for verified users - check waitlist status
    // If waitlist has errors, go to Dashboard (fallback)
    // If waitlist is loading, that's fine - navigate to Waitlist (it will show loading)
    if (kycStatus === 'verified' && !hasNavigatedRef.current && profile !== undefined) {
      hasNavigatedRef.current = true;
      // Check for waitlist errors first - if error, go to Dashboard
      if (waitlistError) {
        navigation.replace('MainTabs', { screen: 'Dashboard' });
      } else if (waitlistEnabled) {
        // Waitlist enabled and no errors - navigate to Waitlist (loading is fine)
        navigation.replace('MainTabs', { screen: 'Waitlist' });
      } else {
        // Waitlist disabled - go to Dashboard
        navigation.replace('MainTabs', { screen: 'Dashboard' });
      }
    }
  }, [profileLoading, kycStatus, waitlistEnabled, waitlistError, navigation, profile]);
  
  // If user is verified, show loading while navigation happens
  // This MUST be checked BEFORE other conditions to prevent showing "Preparing KYC verification..."
  // If waitlist has errors, navigate to Dashboard immediately
  // If waitlist is loading, that's fine - show loading message
  // Check both kycStatus directly and profile?.kyc_status to handle all cases
  if (profile !== undefined && (kycStatus === 'verified' || profile?.kyc_status === 'verified')) {
    // If waitlist has errors, don't show loading - navigate to Dashboard immediately
    if (waitlistError) {
      // Navigation will happen in useEffect, but show loading briefly
      return (
        <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
          <ActivityIndicator size="large" color="#007AFF" />
          <Text style={{ marginTop: 16, color: '#6b7280' }}>
            Redirecting...
          </Text>
        </View>
      );
    }
    // Waitlist loading is fine - show loading message
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
        <ActivityIndicator size="large" color="#007AFF" />
        <Text style={{ marginTop: 16, color: '#6b7280' }}>
          {waitlistLoading ? 'Loading waitlist...' : 'Redirecting...'}
        </Text>
      </View>
    );
  }
  
  // If KYC is completed but not verified (rejected/error), navigate to dashboard
  if (profile !== undefined && isKycCompleted(kycStatus) && kycStatus !== 'verified') {
    // Navigate immediately - don't show KYC screen for rejected/error status
    useLayoutEffect(() => {
      if (!hasNavigatedRef.current) {
        hasNavigatedRef.current = true;
        navigation.replace('MainTabs', { screen: 'Dashboard' });
      }
    }, []);
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
        <ActivityIndicator size="large" color="#007AFF" />
        <Text style={{ marginTop: 16, color: '#6b7280' }}>
          Redirecting...
        </Text>
      </View>
    );
  }
  
  // Show loading while checking status or loading widget
  if (checkingKycStatus || zkMeLoading) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
        <ActivityIndicator size="large" color="#007AFF" />
        <Text style={{ marginTop: 16, color: '#6b7280' }}>
          {checkingKycStatus ? 'Checking verification status...' : 'Loading KYC verification...'}
        </Text>
      </View>
    );
  }

  // If widget should show but component failed to load, show error with retry option
  if (showZkKycWidget && !ZkMeComponent && zkMeError) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb', padding: 20 }}>
        <Text style={{ fontSize: 18, fontWeight: 'bold', color: '#dc2626', marginBottom: 12, textAlign: 'center' }}>
          KYC Verification Error
        </Text>
        <Text style={{ fontSize: 14, color: '#6b7280', marginBottom: 24, textAlign: 'center' }}>
          {zkMeError}
        </Text>
        <TouchableOpacity
          style={{ backgroundColor: '#007AFF', paddingHorizontal: 24, paddingVertical: 12, borderRadius: 8 }}
          onPress={() => {
            setZkMeError(null);
            setZkMeComponent(null);
            setShowZkKycWidget(true);
          }}
        >
          <Text style={{ color: '#fff', fontSize: 16, fontWeight: '600' }}>Retry</Text>
        </TouchableOpacity>
        <TouchableOpacity
          style={{ marginTop: 12, paddingHorizontal: 24, paddingVertical: 12 }}
          onPress={() => {
            setZkMeError(null);
            setShowZkKycWidget(false);
            // Navigate to dashboard only - waitlist should only be shown after KYC completion
            navigation.replace('MainTabs', { screen: 'Dashboard' });
          }}
        >
          <Text style={{ color: '#6b7280', fontSize: 14 }}>Go to Dashboard</Text>
        </TouchableOpacity>
      </View>
    );
  }

  // If widget is requested but component is still loading (shouldn't happen due to loading check above, but safety check)
  if (showZkKycWidget && !ZkMeComponent && !zkMeError) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb' }}>
        <ActivityIndicator size="large" color="#007AFF" />
        <Text style={{ marginTop: 16, color: '#6b7280' }}>Preparing KYC verification...</Text>
        <Text style={{ marginTop: 8, color: '#9ca3af', fontSize: 12 }}>This may take a moment</Text>
      </View>
    );
  }

  // Render zk KYC widget if component is loaded
  if (showZkKycWidget && ZkMeComponent) {
    return (
      <>
        <ZkMeComponent
          visible={showZkKycWidget}
          onClose={() => setShowZkKycWidget(false)}
          onComplete={handleZkKycComplete}
          onError={async (error: Error | string) => {
            console.error('zk KYC widget error:', error);
            const errorMessage = typeof error === 'string' ? error : error.message;
            
            // Check if component is still mounted
            if (!isMountedRef.current) return;
            
            // Update profile status to 'error' to mark KYC as completed with error
            if (user) {
              try {
                await supabase
                  .from('profiles')
                  .update({ kyc_status: 'error' })
                  .eq('user_id', user.id);
                
                if (!isMountedRef.current) return; // Check again after async operation
                
                queryClient.invalidateQueries(['profile', user.id]);
                await queryClient.refetchQueries(['profile', user.id]);
              } catch (updateError) {
                console.error('Error updating profile status to error:', updateError);
              }
            }
            
            if (!isMountedRef.current) return; // Final check before navigating
            
            // Navigate to Dashboard on any error - Dashboard is the default fallback
            setShowZkKycWidget(false);
            navigation.replace('MainTabs', { screen: 'Dashboard' });
          }}
          userId={user?.id}
        />
      </>
    );
  }

  // Fallback: shouldn't normally reach here for verified users
  // Only show this if profile is loaded and KYC is not verified and not completed
  // This means user needs to complete KYC
  if (profile !== undefined && kycStatus !== 'verified' && !isKycCompleted(kycStatus)) {
    return (
      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb', padding: 20 }}>
        <Text style={{ fontSize: 16, color: '#6b7280', textAlign: 'center', marginBottom: 24 }}>
          KYC verification is required to continue.
        </Text>
        <TouchableOpacity
          style={{ backgroundColor: '#007AFF', paddingHorizontal: 24, paddingVertical: 12, borderRadius: 8 }}
          onPress={() => {
            setShowZkKycWidget(true);
          }}
        >
          <Text style={{ color: '#fff', fontSize: 16, fontWeight: '600' }}>Start KYC Verification</Text>
        </TouchableOpacity>
      </View>
    );
  }
  
  // Final fallback: show loading while waiting for profile
  return (
    <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#f9fafb', padding: 20 }}>
      <ActivityIndicator size="large" color="#007AFF" />
      <Text style={{ marginTop: 16, fontSize: 16, color: '#6b7280', textAlign: 'center' }}>
        Loading...
      </Text>
    </View>
  );
};

// Auth Stack Navigator
const AuthStack = createNativeStackNavigator();

const AuthNavigator = () => {
  return (
    <AuthStack.Navigator screenOptions={{ headerShown: false }}>
      <AuthStack.Screen name="Login" component={LoginScreen} />
      <AuthStack.Screen name="SignUp" component={SignUpScreen} />
    </AuthStack.Navigator>
  );
};

// Custom Header Component with Profile Photo
const CustomHeader = ({ title }: { title: string }) => {
  const { profile } = useProfile();
  const navigation = useNavigation();
  
  const handleProfilePress = () => {
    navigation.navigate('Settings' as never, { fromProfileIcon: true } as never);
  };
  
  return (
    <View style={styles.customHeader}>
      <Text style={styles.headerTitle}>{title}</Text>
      <TouchableOpacity 
        style={styles.headerProfileContainer}
        onPress={handleProfilePress}
        activeOpacity={0.7}
      >
        {profile?.avatar_url ? (
          <Image 
            source={{ uri: profile.avatar_url }} 
            style={styles.headerAvatar}
            resizeMode="cover"
          />
        ) : (
          <View style={styles.headerAvatarPlaceholder}>
            <Text style={styles.headerAvatarText}>
              {profile?.first_name?.[0] || 'U'}
            </Text>
          </View>
        )}
      </TouchableOpacity>
    </View>
  );
};

// Tab Navigator - Memoized to prevent unnecessary re-renders
const TabNavigator = React.memo(() => {
  const adminCheck = useAdminCheck();
  const { trackEvent, deviceFingerprint, isInitialized } = useDeviceFingerprinting();
  const { enabled: waitlistEnabled, error: waitlistError } = useWaitlistEnabled();
  const { profile } = useProfile();
  const navigation = useNavigation();
  const isAdmin = adminCheck?.isAdmin || false;
  
  // Get current route name and params to conditionally hide tab bar for Dashboard and Settings (from profile icon)
  // Handle nested navigation states properly
  const routeInfo = useNavigationState(state => {
    if (!state) return { name: undefined, params: undefined };
    const route = state.routes[state.index || 0];
    // If route has nested state (like TabNavigator), check the nested route
    if (route?.state?.routes && route.state.index !== undefined) {
      const nestedRoute = route.state.routes[route.state.index];
      return { name: nestedRoute?.name, params: nestedRoute?.params };
    }
    return { name: route?.name, params: route?.params };
  });
  
  // Check if Dashboard exists in TabNavigator routes (indicates dummy dashboard mode)
  const isDummyDashboardMode = useNavigationState(state => {
    if (!state) return false;
    // Check if Dashboard is one of the routes in TabNavigator
    const routes = state.routes || [];
    return routes.some((route: any) => route.name === 'Dashboard');
  });
  
  // State to track if tab bar should be hidden
  // Hide when: Dashboard is active OR (Settings from profile icon AND in dummy dashboard mode)
  const [shouldHideTabBar, setShouldHideTabBar] = useState(() => {
    const isDashboard = routeInfo.name === 'Dashboard';
    const isSettingsFromProfile = routeInfo.name === 'Settings' && routeInfo.params?.fromProfileIcon === true;
    return isDashboard || (isSettingsFromProfile && isDummyDashboardMode);
  });
  
  // Update tab bar visibility immediately when route changes
  useEffect(() => {
    const isDashboard = routeInfo.name === 'Dashboard';
    const isSettingsFromProfile = routeInfo.name === 'Settings' && routeInfo.params?.fromProfileIcon === true;
    setShouldHideTabBar(isDashboard || (isSettingsFromProfile && isDummyDashboardMode));
  }, [routeInfo, isDummyDashboardMode]);
  
  // Check KYC completion before allowing access to Waitlist
  const handleWaitlistFocus = useCallback(() => {
    const kycStatus = profile?.kyc_status;
    // Only allow access to waitlist if KYC is verified
    // Check for undefined/null explicitly to handle loading state
    if (kycStatus === undefined || kycStatus === null || kycStatus !== 'verified') {
      // Redirect to Dashboard tab if KYC is not verified
      // Waitlist should only be accessible after KYC completion
      // Since we're in TabNavigator, we can navigate directly to the Dashboard tab
      (navigation as any).navigate('Dashboard');
    }
  }, [profile, navigation]);
  
  // Track screen views automatically
  const handleScreenChange = useCallback((routeName: string) => {
    if (isInitialized && deviceFingerprint) {
      trackEvent('screen_view', {
        screen_name: routeName,
        device_id: deviceFingerprint.device_id,
      });
    }
  }, [isInitialized, deviceFingerprint, trackEvent]);
  
  return (
    <Tab.Navigator
      screenOptions={({ route }) => ({
        tabBarIcon: ({ focused, color, size }) => {
          let iconName: string;

          switch (route.name) {
            case 'Dashboard':
              iconName = focused ? 'home' : 'home-outline';
              break;
            case 'Activity':
              iconName = focused ? 'pulse' : 'pulse-outline';
              break;
            case 'Surveys':
              iconName = focused ? 'list' : 'list-outline';
              break;
            case 'Waitlist':
              iconName = focused ? 'list-circle' : 'list-circle-outline';
              break;
            case 'Leaderboard':
              iconName = focused ? 'trophy' : 'trophy-outline';
              break;
            case 'Settings':
              iconName = focused ? 'settings' : 'settings-outline';
              break;
            case 'Admin':
              iconName = focused ? 'shield' : 'shield-outline';
              break;
            default:
              iconName = 'home-outline';
          }

          return <Icon name={iconName} size={size} color={color} />;
        },
        tabBarActiveTintColor: '#007AFF',
        tabBarInactiveTintColor: 'gray',
        headerShown: true,
        header: ({ route }) => <CustomHeader title={route.name} />,
        headerStyle: {
          backgroundColor: '#f8f9fa',
        },
        // Hide tab bar when Dashboard is active or Settings is accessed from profile icon - hide immediately
        tabBarStyle: shouldHideTabBar ? { 
          height: 0, 
          borderTopWidth: 0, 
          opacity: 0, 
          position: 'absolute',
          overflow: 'hidden',
          pointerEvents: 'none'
        } : undefined,
      })}
      screenListeners={{
        focus: (e) => {
          const screenName = e.target?.split('-')[0] || 'unknown';
          handleScreenChange(screenName);
          // Immediately update tab bar visibility when screen is focused
          // Check route params to see if Settings was accessed from profile icon
          const state = navigation.getState();
          let isSettingsFromProfile = false;
          if (screenName === 'Settings' && state?.routes) {
            const route = state.routes[state.index || 0];
            if (route?.state?.routes && route.state.index !== undefined) {
              const nestedRoute = route.state.routes[route.state.index];
              isSettingsFromProfile = nestedRoute?.params?.fromProfileIcon === true;
            } else {
              isSettingsFromProfile = route?.params?.fromProfileIcon === true;
            }
          }
          // Hide tab bar only if Dashboard is active OR (Settings from profile icon AND in dummy dashboard mode)
          setShouldHideTabBar(screenName === 'Dashboard' || (isSettingsFromProfile && isDummyDashboardMode));
        },
      }}
    >
      <Tab.Screen 
        name="Dashboard" 
        component={DashboardScreen}
        options={{ title: 'Dashboard' }}
      />
      <Tab.Screen
        name="Activity" 
        options={{ title: 'Activity' }}
      >
        {() => (
          <ErrorBoundary>
            <ActivityScreen />
          </ErrorBoundary>
        )}
      </Tab.Screen>
      <Tab.Screen 
        name="Surveys" 
        component={SurveysScreen}
        options={{ title: 'Surveys' }}
      />
      {waitlistEnabled && !waitlistError && (
        <>
          <Tab.Screen
            name="Waitlist"
            component={WaitlistDashboard}
            options={{ title: 'Waitlist' }}
            listeners={{
              focus: () => {
                handleScreenChange('Waitlist');
                handleWaitlistFocus();
              },
            }}
          />
          <Tab.Screen
            name="Leaderboard"
            component={Leaderboard}
            options={{ title: 'Leaderboard' }}
          />
        </>
      )}
      <Tab.Screen 
        name="Settings" 
        component={SettingsScreen}
        options={{ title: 'Settings' }}
      />
      {isAdmin && (
        <Tab.Screen 
          name="Admin" 
          component={AdminScreen}
          options={{ title: 'Admin' }}
        />
      )}
    </Tab.Navigator>
  );
});

// Main App with Auth Logic
const MainApp = () => {
  const { loading, isAuthenticated, user } = useAuth();
  const { trackEvent, deviceFingerprint, isInitialized } = useDeviceFingerprinting();
  const navigationRef = useRef<any>(null);
  const routeNameRef = useRef<string | undefined>(undefined);
  const statusCheckTimeoutRef = useRef<NodeJS.Timeout | null>(null);
  const profileLoadingTimeoutRef = useRef<NodeJS.Timeout | null>(null);
  const isMountedRef = useRef(true);
  const { profile, loading: profileLoading } = useProfile();
  // Make waitlist check non-blocking - don't wait for it to load
  // If waitlist check fails or is loading, default to showing Waitlist (it will handle errors internally)
  let waitlistEnabled = true; // Default to enabled
  let waitlistError: any = null;
  try {
    const waitlistHook = useWaitlistEnabled();
    waitlistEnabled = waitlistHook?.enabled ?? true;
    waitlistError = waitlistHook?.error ?? null;
  } catch (e) {
    // If waitlist hook fails, default to enabled (non-blocking)
    console.warn('Waitlist hook error, defaulting to enabled:', e);
  }
  const queryClient = useQueryClient();

  // Set mounted flag on mount and cleanup on unmount
  useEffect(() => {
    isMountedRef.current = true;
    return () => {
      isMountedRef.current = false;
      // Cleanup timeouts on unmount
      if (statusCheckTimeoutRef.current) {
        clearTimeout(statusCheckTimeoutRef.current);
        statusCheckTimeoutRef.current = null;
      }
      if (profileLoadingTimeoutRef.current) {
        clearTimeout(profileLoadingTimeoutRef.current);
        profileLoadingTimeoutRef.current = null;
      }
    };
  }, []);
  
  // Initialize Expo Gmail Auth Service when app starts
  useEffect(() => {
    const initializeGmailAuth = async () => {
      try {
        const gmailAuthService = RealGmailAuthService.getInstance();
        const testResult = await gmailAuthService.testConfiguration();
        if (testResult.success) {
          console.log('Expo Gmail Auth Service initialized successfully');
        } else {
          console.error('Expo Gmail Auth Service configuration failed:', testResult.error);
        }
      } catch (error) {
        console.error('Failed to initialize Expo Gmail Auth Service:', error);
      }
    };
    
    initializeGmailAuth();
  }, []);
  
  // Track app lifecycle events automatically
  useEffect(() => {
    if (isInitialized && deviceFingerprint) {
      trackEvent('app_lifecycle', {
        event: 'app_started',
        device_id: deviceFingerprint.device_id,
        os_type: deviceFingerprint.os_type,
        app_version: deviceFingerprint.app_version,
      });
    }
  }, [isInitialized, deviceFingerprint, trackEvent]);

  // Track authentication state changes
  useEffect(() => {
    if (isInitialized && deviceFingerprint) {
      trackEvent('auth_state_change', {
        is_authenticated: isAuthenticated,
        device_id: deviceFingerprint.device_id,
      });
    }
  }, [isAuthenticated, isInitialized, deviceFingerprint, trackEvent]);

  // State for zk KYC widget
  const [showZkKycWidget, setShowZkKycWidget] = useState(false);
  const [checkingZkKycStatus, setCheckingZkKycStatus] = useState(false);
  const [ZkMeComponent, setZkMeComponent] = useState<React.ComponentType<any> | null>(null);
  const [zkMeLoading, setZkMeLoading] = useState(false);

  // Lazy load ZkMe component only when showZkKycWidget becomes true
  useEffect(() => {
    if (showZkKycWidget && !ZkMeComponent && !zkMeLoading) {
      setZkMeLoading(true);
      import('./components/ZkMeWebView')
        .then((module) => {
          if (!showZkKycWidget) {
            setZkMeLoading(false);
            return;
          }
          try {
            const ZkMeWebView = module.default || module.ZkMeWebView;
            if (!ZkMeWebView) {
              throw new Error('ZkMe component export is undefined or invalid');
            }
            if (typeof ZkMeWebView !== 'function' && typeof ZkMeWebView !== 'object') {
              throw new Error('ZkMe component is not a valid React component');
            }
            setZkMeComponent(() => ZkMeWebView);
            setZkMeLoading(false);
          } catch (error: any) {
            console.error('Failed to initialize ZkMe component:', error);
            setZkMeLoading(false);
            setShowZkKycWidget(false);
            Alert.alert(
              'KYC Verification Error',
              'Failed to initialize KYC verification. Please check your configuration and try again later.',
              [{ text: 'OK' }]
            );
          }
        })
        .catch((error: any) => {
          if (showZkKycWidget) {
            console.error('Failed to load ZkMe component module:', error);
            setZkMeLoading(false);
            setShowZkKycWidget(false);
            Alert.alert(
              'KYC Verification Error',
              'Failed to load KYC verification component. Please try again later.',
              [{ text: 'OK' }]
            );
          } else {
            setZkMeLoading(false);
          }
        });
    }
  }, [showZkKycWidget, ZkMeComponent, zkMeLoading]);

  // Cleanup when showZkKycWidget becomes false
  useEffect(() => {
    if (!showZkKycWidget) {
      setZkMeComponent(null);
      setZkMeLoading(false);
    }
  }, [showZkKycWidget]);

  // Check zk KYC status function (reuse from SettingsScreen)
  const checkZkMeVerificationStatus = async (): Promise<'verified' | 'pending' | 'error'> => {
    try {
      if (!user || !user.email) {
        console.error('No user or user email found for status check');
        return 'error';
      }

      // Get zkMe configuration (appId/mchNo) from database
      let appId = '';
      try {
        const configService = AppConfigurationService.getInstance();
        const zkmeConfig = await configService.getZkMeConfig();
        appId = zkmeConfig.mchNo;
      } catch (error) {
        console.error('Error fetching ZkMe configuration from database:', error);
        return 'error';
      }

      if (!appId) {
        console.error('zkMe appId (MCH_NO) is not configured in database');
        return 'error';
      }

      // Get current app status
      const currentAppStatus = profile?.kyc_status || 'pending';

      // Check status from zkMe API using verifyKycWithZkMeServices
      let programNo: string | undefined;
      try {
        const configService = AppConfigurationService.getInstance();
        const programNoValue = await configService.getConfigValue('zkme_program_no');
        programNo = programNoValue || undefined;
      } catch (error) {
        console.warn('Error fetching zkme_program_no from database, proceeding without it:', error);
      }

      const { isGrant } = await verifyKycWithZkMeServices(
        appId,
        user.id,
        programNo ? { programNo } : undefined
      );

      console.log('zkMe verification check result:', { isGrant, currentAppStatus });

      // Flow: If zkMe API returns verified (isGrant = true) but app DB shows pending, update app DB to verified
      if (isGrant && currentAppStatus === 'pending') {
        console.log('ZkMe status is verified but app status is pending. Updating app status...');
        
        // Update profile status to verified
        const { error: updateError } = await supabase
          .from('profiles')
          .update({ kyc_status: 'verified' })
          .eq('user_id', user.id);

        if (updateError) {
          console.error('Error updating profile status:', updateError);
          return 'error';
        }

        // Also update the submission if it exists
        const { data: submission } = await supabase
          .from('kyc_submissions')
          .select('id, verified_attributes')
          .eq('user_id', user.id)
          .eq('verification_method', 'zkme')
          .order('created_at', { ascending: false })
          .limit(1)
          .maybeSingle();

        if (submission && Array.isArray(submission.verified_attributes)) {
          const updatedAttributes = submission.verified_attributes.map((cred: any) => ({
            ...cred,
            status: 'verified'
          }));

          const { error: submissionUpdateError } = await supabase
            .from('kyc_submissions')
            .update({ verified_attributes: updatedAttributes })
            .eq('id', submission.id);

          if (submissionUpdateError) {
            console.error('Error updating submission:', submissionUpdateError);
          }
        }

        // Invalidate and refetch profile data immediately
        queryClient.invalidateQueries(['profile', user.id]);
        await queryClient.refetchQueries(['profile', user.id]);
        return 'verified';
      }

      // If zkMe says verified and app also says verified, return verified
      if (isGrant && currentAppStatus === 'verified') {
        return 'verified';
      }

      // If zkMe says not verified (isGrant = false), check database as fallback
      const { data: submission } = await supabase
        .from('kyc_submissions')
        .select('verified_attributes, created_at')
        .eq('user_id', user.id)
        .eq('verification_method', 'zkme')
        .order('created_at', { ascending: false })
        .limit(1)
        .maybeSingle();

      const credentials = submission?.verified_attributes;
      if (Array.isArray(credentials) && credentials.length > 0) {
        const hasVerifiedCredential = credentials.some(
          (cred: any) => cred?.status === 'verified'
        );
        
        if (hasVerifiedCredential) {
          if (currentAppStatus === 'pending') {
            const { error: updateError } = await supabase
              .from('profiles')
              .update({ kyc_status: 'verified' })
              .eq('user_id', user.id);

            if (updateError) {
              console.error('Error updating profile status:', updateError);
              return 'error';
            }

            queryClient.invalidateQueries(['profile', user.id]);
            await queryClient.refetchQueries(['profile', user.id]);
          }
          return 'verified';
        }
      }
      
      // If zkMe says not verified and no verified credentials in DB, return pending
      return 'pending';
    } catch (error) {
      console.error('Error checking ZkMe verification status:', error);
      return 'error';
    }
  };

  // Handle zk KYC completion
  const handleZkKycComplete = async (result: any) => {
    try {
      console.log('zk KYC verification completed:', result);
      
      if (!user) {
        console.error('No user found for KYC update');
        Alert.alert('Error', 'No user found. Please log in and try again.');
        return;
      }

      // Parse the result from ZkMeWebView
      let verificationPayload: ZkMeVerificationPayload | null = null;

      if (result?.verification_id && result?.credentials) {
        verificationPayload = {
          verification_id: result.verification_id,
          credentials: result.credentials
        };
      } else if (result?.verificationId && result?.credentials) {
        verificationPayload = {
          verification_id: result.verificationId,
          credentials: result.credentials
        };
      } else if (result?.type === 'zkme-verification-complete' && result?.result) {
        const nestedResult = result.result;
        if (nestedResult?.verification_id || nestedResult?.verificationId) {
          verificationPayload = {
            verification_id: nestedResult.verification_id || nestedResult.verificationId,
            credentials: nestedResult.credentials || []
          };
        }
      }

      if (verificationPayload) {
        await submitZkMeVerification(user.id, verificationPayload);
        
        if (!isMountedRef.current) return; // Check if still mounted after async operation
        
        // Update profile status to pending
        const { error: updateError } = await supabase
          .from('profiles')
          .update({ kyc_status: 'pending' })
          .eq('user_id', user.id);

        if (updateError) {
          console.error('Error updating profile status:', updateError);
        }

        if (!isMountedRef.current) return; // Check again after async operation

        // Invalidate and refetch profile data
        queryClient.invalidateQueries(['profile', user.id]);
        await queryClient.refetchQueries(['profile', user.id]);
      }

      if (!isMountedRef.current) return; // Check before updating state
      // Close widget
      setShowZkKycWidget(false);

      // Clear any existing status check timeout
      if (statusCheckTimeoutRef.current) {
        clearTimeout(statusCheckTimeoutRef.current);
        statusCheckTimeoutRef.current = null;
      }

      // Check status again after a short delay
      statusCheckTimeoutRef.current = setTimeout(async () => {
        // Check if component is still mounted before navigating
        if (!isMountedRef.current) return;
        
        const status = await checkZkMeVerificationStatus();
        if (!isMountedRef.current) return; // Check again after async operation
        
        if (status === 'verified') {
          // Only navigate to waitlist if KYC is verified AND no errors
          if (navigationRef.current) {
            const initialScreen = (waitlistEnabled && !waitlistError) ? 'Waitlist' : 'Dashboard';
            navigationRef.current.reset({
              index: 0,
              routes: [{ name: 'MainTabs', params: { screen: initialScreen } }],
            });
          }
        } else {
          // KYC not verified yet - go to dashboard, not waitlist
          // Waitlist should only be shown after KYC completion
          if (navigationRef.current) {
            navigationRef.current.reset({
              index: 0,
              routes: [{ name: 'MainTabs', params: { screen: 'Dashboard' } }],
            });
          }
        }
        statusCheckTimeoutRef.current = null;
      }, 1000);
    } catch (error: any) {
      console.error('Error handling zk KYC completion:', error);
      
      // Update profile status to 'error' to mark KYC as completed with error
      if (user) {
        try {
          await supabase
            .from('profiles')
            .update({ kyc_status: 'error' })
            .eq('user_id', user.id);
          
          queryClient.invalidateQueries(['profile', user.id]);
          await queryClient.refetchQueries(['profile', user.id]);
        } catch (updateError) {
          console.error('Error updating profile status to error:', updateError);
        }
      }
      
      Alert.alert(
        'KYC Verification Error',
        'Failed to process KYC verification. You can try again later.',
        [
          {
            text: 'OK',
            onPress: () => {
              setShowZkKycWidget(false);
              // Navigate to Dashboard - waitlist should only be shown after successful KYC
              if (navigationRef.current) {
                navigationRef.current.reset({
                  index: 0,
                  routes: [{ name: 'MainTabs', params: { screen: 'Dashboard' } }],
                });
              }
            }
          }
        ]
      );
    }
  };

  // Track if we've already checked KYC status for this session
  const hasCheckedKycRef = useRef(false);

  // Navigate based on KYC status after authentication
  useEffect(() => {
    // Allow navigation if authenticated and not loading
    // Don't wait for checkingZkKycStatus - navigate immediately, KYC screen will handle checks
    if (isAuthenticated && !loading && user && navigationRef.current) {
      const currentRoute = navigationRef.current.getCurrentRoute();
      
      // Navigate immediately if no profile - don't wait for profile to load
      // KYC screen will handle loading state and profile checks
      if (!profile) {
        // No profile yet - navigate to KYC screen immediately
        if (currentRoute?.name !== 'KYC' && currentRoute?.name !== 'MainTabs') {
          navigationRef.current.reset({
            index: 0,
            routes: [{ name: 'KYC' }],
          });
        }
        return;
      }
      
      // Clear timeout if profile loaded successfully
      if (profileLoadingTimeoutRef.current) {
        clearTimeout(profileLoadingTimeoutRef.current);
        profileLoadingTimeoutRef.current = null;
      }
      
      const kycStatus = profile?.kyc_status;

      // If KYC is verified, navigate based on waitlist status
      // If waitlist has errors, go to Dashboard (fallback)
      // If waitlist is loading, that's fine - navigate to Waitlist (it will show loading)
      if (kycStatus === 'verified') {
        // Check for waitlist errors first - if error, go to Dashboard
        let initialScreen = 'Waitlist';
        if (waitlistError) {
          initialScreen = 'Dashboard';
        } else if (!waitlistEnabled) {
          initialScreen = 'Dashboard';
        }
        if (currentRoute?.name !== 'MainTabs') {
          navigationRef.current.reset({
            index: 0,
            routes: [{ name: 'MainTabs', params: { screen: initialScreen } }],
          });
        } else {
          // Already on MainTabs, switch to Waitlist if needed
          const currentTabRoute = (currentRoute as any)?.state?.routes?.[(currentRoute as any)?.state?.index || 0];
          if (currentTabRoute?.name !== initialScreen) {
            navigationRef.current.navigate('MainTabs', { screen: initialScreen });
          }
        }
        hasCheckedKycRef.current = true;
      } else if (isKycCompleted(kycStatus) && kycStatus !== 'verified') {
        // KYC completed but not verified (rejected/error) - go to dashboard as fallback
        if (currentRoute?.name !== 'MainTabs') {
          navigationRef.current.reset({
            index: 0,
            routes: [{ name: 'MainTabs', params: { screen: 'Dashboard' } }],
          });
        }
        hasCheckedKycRef.current = true;
      } else {
        // KYC is not verified - navigate to KYC screen immediately
        // Don't wait for zk check - navigate first, KYC screen will handle the check
        if (currentRoute?.name !== 'KYC' && currentRoute?.name !== 'MainTabs') {
          // Navigate to KYC screen immediately - don't block on zk check
          navigationRef.current.reset({
            index: 0,
            routes: [{ name: 'KYC' }],
          });
          hasCheckedKycRef.current = true;
        }
      }
    }
    
    // Reset check flag when user signs out
    if (!isAuthenticated) {
      hasCheckedKycRef.current = false;
    }
  }, [isAuthenticated, loading, profileLoading, profile?.kyc_status, user, waitlistEnabled, waitlistError]);

  if (loading) {
    return (
      <View style={styles.container}>
        <Text style={styles.title}>Loading...</Text>
      </View>
    );
  }

  return (
    <>
      <NavigationContainer
        ref={navigationRef}
      >
        <Stack.Navigator screenOptions={{ headerShown: false }}>
          {isAuthenticated ? (
            <>
              <Stack.Screen name="KYC" component={KYCScreen} />
              <Stack.Screen name="MainTabs" component={TabNavigator} />
            </>
          ) : (
            <Stack.Screen name="Auth" component={AuthNavigator} />
          )}
        </Stack.Navigator>
      </NavigationContainer>
      
      {/* Render zk KYC widget when needed */}
      {showZkKycWidget && ZkMeComponent && (
        <ZkMeComponent
          visible={showZkKycWidget}
          onClose={() => setShowZkKycWidget(false)}
          onComplete={handleZkKycComplete}
          onError={(error: Error | string) => {
            console.error('zk KYC widget error:', error);
            Alert.alert('Error', typeof error === 'string' ? error : error.message);
            setShowZkKycWidget(false);
          }}
          userId={user?.id}
        />
      )}
    </>
  );
};

const App = () => {
  // Wrap entire app in try-catch to prevent crashes
  try {
    return (
      <QueryClientProvider client={queryClient}>
        <AuthProvider>
          <DeviceFingerprintingProvider>
            <ErrorBoundary onError={(error) => {
              try {
                console.error('App Error:', error);
                // Try to log to errorLogger if available
                if (errorLogger && typeof errorLogger.logError === 'function') {
                  errorLogger.logError('App Component Error', error);
                }
              } catch (logError) {
                // Ignore logging errors
              }
            }}>
              <MainApp />
            </ErrorBoundary>
          </DeviceFingerprintingProvider>
        </AuthProvider>
      </QueryClientProvider>
    );
  } catch (error) {
    // Fallback UI if app fails to render
    const React = require('react');
    const { View, Text } = require('react-native');
    return React.createElement(View, { 
      style: { flex: 1, justifyContent: 'center', alignItems: 'center', padding: 20 } 
    }, 
      React.createElement(Text, { style: { fontSize: 16, color: '#ff0000', textAlign: 'center' } }, 
        'App failed to initialize. Please restart the app.'
      )
    );
  }
};

