                        </View>
                      </View>
                      <View style={[styles.kycBadge, { backgroundColor: getKYCStatusColor(profile?.kyc_status) }]}>
                        <Text style={styles.kycBadgeText}>
                          {getKYCStatusText(profile?.kyc_status)}
                        </Text>
                      </View>
                    </View>
